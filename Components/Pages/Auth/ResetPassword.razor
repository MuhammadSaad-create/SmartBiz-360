@page "/reset-password"
@rendermode InteractiveServer
@layout EmptyLayout
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="login-page">
    <div class="login-card">
        <div class="login-logo">
            <div class="login-logo-icon">SB</div>
            <h2>SmartBiz 360</h2>
        </div>

        @if (resetDone)
        {
            <div style="text-align:center;padding:1rem 0;">
                <div style="font-size:2.5rem;margin-bottom:0.75rem;">✅</div>
                <h3 style="margin-bottom:0.5rem;">Password Reset!</h3>
                <p class="subtitle">
                    Your password has been updated. You can now sign in.
                </p>
                <button class="btn-login"
                        style="margin-top:1.5rem;"
                        @onclick="GoToLogin">
                    Go to Login
                </button>
            </div>
        }
        else if (tokenInvalid)
        {
            <div style="text-align:center;padding:1rem 0;">
                <div style="font-size:2.5rem;margin-bottom:0.75rem;">⛔</div>
                <h3 style="margin-bottom:0.5rem;">Link Expired</h3>
                <p class="subtitle">
                    This reset link is invalid or has already been used.
                    Please request a new one.
                </p>
                <button class="btn-login"
                        style="margin-top:1.5rem;"
                        @onclick='() => Navigation.NavigateTo("/forgot-password")'>
                    Request New Link
                </button>
            </div>
        }
        else
        {
            <h3>Set New Password</h3>
            <p class="subtitle">Choose a strong new password for your account.</p>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert-error">@errorMessage</div>
            }

            <div class="form-group">
                <label>New Password</label>
                <input type="password"
                       @bind="newPassword"
                       placeholder="Min 6 characters"
                       disabled="@isLoading" />
            </div>

            <div class="form-group">
                <label>Confirm Password</label>
                <input type="password"
                       @bind="confirmPassword"
                       placeholder="Repeat new password"
                       disabled="@isLoading" />
            </div>

            <button class="btn-login"
                    @onclick="HandleReset"
                    disabled="@isLoading">
                @(isLoading ? "Saving…" : "Reset Password")
            </button>
        }
    </div>
</div>

@code {
    [SupplyParameterFromQuery(Name = "token")]
    public string? Token { get; set; }

    private string newPassword = "";
    private string confirmPassword = "";
    private string errorMessage = "";
    private bool isLoading = false;
    private bool resetDone = false;
    private bool tokenInvalid = false;

    protected override async Task OnInitializedAsync()
    {
        if (string.IsNullOrWhiteSpace(Token))
        {
            tokenInvalid = true;
            return;
        }

        // Validate token exists and is not expired
        bool valid = await AuthService.IsResetTokenValidAsync(Token);
        if (!valid) tokenInvalid = true;
    }

    private async Task HandleReset()
    {
        errorMessage = "";

        if (string.IsNullOrWhiteSpace(newPassword) ||
            string.IsNullOrWhiteSpace(confirmPassword))
        {
            errorMessage = "Please fill in both password fields.";
            return;
        }

        if (newPassword.Length < 6)
        {
            errorMessage = "Password must be at least 6 characters.";
            return;
        }

        if (newPassword != confirmPassword)
        {
            errorMessage = "Passwords do not match.";
            return;
        }

        isLoading = true;

        bool success = await AuthService.ResetPasswordAsync(Token!, newPassword);

        isLoading = false;

        if (success)
            resetDone = true;
        else
        {
            tokenInvalid = true;
        }
    }

    private void GoToLogin() => Navigation.NavigateTo("/login");
}
