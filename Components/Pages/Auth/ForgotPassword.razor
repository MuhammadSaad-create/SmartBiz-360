@page "/forgot-password"
@rendermode InteractiveServer
@layout EmptyLayout
@inject AuthService AuthService
@inject NavigationManager Navigation

<div class="login-page">
    <div class="login-card">
        <div class="login-logo">
            <div class="login-logo-icon">SB</div>
            <h2>SmartBiz 360</h2>
        </div>

        @if (emailSent)
        {
            <div style="text-align:center;padding:1rem 0;">
                <div style="font-size:2.5rem;margin-bottom:0.75rem;">📧</div>
                <h3 style="margin-bottom:0.5rem;">Check Your Email</h3>
                <p class="subtitle">
                    If <strong>@email</strong> is registered, a reset link
                    has been sent. Check your inbox (and spam folder).
                </p>
                <button class="btn-login"
                        style="margin-top:1.5rem;"
                        @onclick="GoToLogin">
                    Back to Login
                </button>
            </div>
        }
        else
        {
            <h3>Forgot Password</h3>
            <p class="subtitle">
                Enter your account email and we'll send you a reset link.
            </p>

            @if (!string.IsNullOrEmpty(errorMessage))
            {
                <div class="alert-error">@errorMessage</div>
            }

            <div class="form-group">
                <label>Email Address</label>
                <input type="email"
                       @bind="email"
                       placeholder="name@company.com"
                       disabled="@isLoading" />
            </div>

            <button class="btn-login"
                    @onclick="HandleSubmit"
                    disabled="@isLoading">
                @(isLoading ? "Sending…" : "Send Reset Link")
            </button>

            <div class="login-footer">
                <a href="/login"
                   style="color:#3b82f6;text-decoration:none;">
                    ← Back to Login
                </a>
            </div>
        }
    </div>
</div>

@code {
    private string email = "";
    private string errorMessage = "";
    private bool isLoading = false;
    private bool emailSent = false;

    private async Task HandleSubmit()
    {
        errorMessage = "";

        if (string.IsNullOrWhiteSpace(email))
        {
            errorMessage = "Please enter your email address.";
            return;
        }

        isLoading = true;

        // Always shows success to prevent email enumeration attacks
        await AuthService.SendPasswordResetAsync(email.Trim().ToLower(), Navigation.BaseUri);

        isLoading = false;
        emailSent = true;
    }

    private void GoToLogin() => Navigation.NavigateTo("/login");
}
