@page "/login"
@rendermode InteractiveServer
@layout EmptyLayout
@inject AuthService AuthService
@inject SessionService SessionService
@inject JwtService JwtService
@inject NavigationManager Navigation
@inject IJSRuntime JS

<div class="login-page">
    <div class="login-card">
        <div class="login-logo">
            <div class="login-logo-icon">SB</div>
            <h2>SmartBiz 360</h2>
        </div>

        <h3>Welcome Back</h3>
        <p class="subtitle">Enter your credentials to access your dashboard.</p>

        @if (!string.IsNullOrEmpty(errorMessage))
        {
            <div class="alert-error">@errorMessage</div>
        }

        <div class="form-group">
            <label>Email Address</label>
            <input type="email" @bind="email"
                   placeholder="name@company.com" />
        </div>

        <div class="form-group">
            <div style="display:flex;justify-content:space-between;
                align-items:center;margin-bottom:0.4rem;">
                <label style="margin:0;">Password</label>
                <a href="/forgot-password"
                   style="font-size:0.8rem;color:#3b82f6;
                    text-decoration:none;">
                    Forgot password?
                </a>
            </div>
            <input type="password" @bind="password"
                   placeholder="••••••••" />
        </div>

        <button class="btn-login" @onclick="HandleLogin">Sign In</button>

        <div class="login-footer">
            Secure login powered by JWT authentication
        </div>
    </div>
</div>

@code {
    private string email = "";
    private string password = "";
    private string errorMessage = "";

    private async Task HandleLogin()
    {
        errorMessage = "";

        if (string.IsNullOrWhiteSpace(email) ||
            string.IsNullOrWhiteSpace(password))
        {
            errorMessage = "Please enter email and password.";
            return;
        }

        var user = await AuthService.LoginAsync(email, password);

        if (user == null)
        {
            errorMessage = "Invalid email or password.";
            return;
        }

        var token = JwtService.GenerateToken(user);
        SessionService.Login(user, token);

        using var http = new HttpClient();
        http.BaseAddress = new Uri(Navigation.BaseUri);
        await http.PostAsJsonAsync("api/session/save",
            new { Token = token });

        Navigation.NavigateTo("/dashboard");
    }
}
