@page "/task-report"
@layout EmptyLayout
@inject TaskReportService TaskReportService
@inject TaskService TaskService
@inject EmailService EmailService
@inject SessionService SessionService
@inject NavigationManager Navigation

<div class="dashboard-layout">

    <AppSidebar CurrentPage="task-report" />

    <div class="main-content">
        <div class="topbar">
            <div>
                <h2 class="page-title">📊 Task Report Generator</h2>
                <p style="color:#6b7280;margin:0;font-size:0.875rem;">
                    Generate performance reports and grade employees based on tasks
                </p>
            </div>
            @if (IsAdminOrManager)
            {
                <div class="topbar-right">
                    <button class="btn-primary" @onclick="ShowGenerateModal">
                        ⚡ Generate Report
                    </button>
                </div>
            }
        </div>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="@(isError ? "alert-error" : "alert-success")"
                 style="margin:1rem 0;">@message</div>
        }

        <!-- Grade Legend -->
        <div style="display:flex;gap:0.75rem;flex-wrap:wrap;margin-bottom:1.5rem;">
            <div class="grade-badge grade-excellent">🏆 Excellent — Bonus Eligible</div>
            <div class="grade-badge grade-average">📊 Average — No Bonus</div>
            <div class="grade-badge grade-warning">⚠️ Warning</div>
            <div class="grade-badge grade-serious">🚨 Serious Warning</div>
        </div>

        @if (isLoading)
        {
            <div style="text-align:center;padding:3rem;color:#6b7280;">
                <div style="font-size:2rem;">⏳</div>
                <p>Loading reports...</p>
            </div>
        }
        else if (!reports.Any())
        {
            <div style="text-align:center;padding:4rem;background:white;
                        border-radius:12px;border:2px dashed #e2e8f0;">
                <div style="font-size:3rem;">📋</div>
                <h3 style="color:#374151;margin:0.5rem 0;">No Reports Yet</h3>
                <p style="color:#6b7280;">
                    @if (IsAdminOrManager)
                    {
                        <span>Click "Generate Report" to create the first performance report.</span>
                    }
                    else
                    {
                        <span>No performance reports have been generated for you yet.</span>
                    }
                </p>
            </div>
        }
        else
        {
            <!-- Summary Cards -->
            <div style="display:grid;grid-template-columns:repeat(auto-fit,minmax(180px,1fr));
                        gap:1rem;margin-bottom:1.5rem;">
                <div class="stat-card">
                    <div class="stat-value">@reports.Count</div>
                    <div class="stat-label">Total Reports</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" style="color:#16a34a;">
                        @reports.Count(r => r.Grade == "Excellent")
                    </div>
                    <div class="stat-label">Excellent</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" style="color:#ca8a04;">
                        @reports.Count(r => r.Grade == "Average")
                    </div>
                    <div class="stat-label">Average</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" style="color:#dc2626;">
                        @reports.Count(r => r.Grade == "Warning" || r.Grade == "Serious Warning")
                    </div>
                    <div class="stat-label">Warnings</div>
                </div>
                <div class="stat-card">
                    <div class="stat-value" style="color:#16a34a;">
                        @reports.Count(r => r.BonusEligible)
                    </div>
                    <div class="stat-label">Bonus Eligible</div>
                </div>
            </div>

            <!-- Reports Table -->
            <div class="card" style="overflow:hidden;">
                <div style="overflow-x:auto;">
                    <table style="width:100%;border-collapse:collapse;">
                        <thead>
                            <tr style="background:#f8fafc;border-bottom:2px solid #e2e8f0;">
                                <th class="table-th">Employee</th>
                                <th class="table-th">Generated</th>
                                <th class="table-th">Tasks</th>
                                <th class="table-th">Completed</th>
                                <th class="table-th">Overdue</th>
                                <th class="table-th">Completion %</th>
                                <th class="table-th">On-Time %</th>
                                <th class="table-th">Grade</th>
                                <th class="table-th">Bonus</th>
                                <th class="table-th">Email</th>
                                @if (IsAdminOrManager)
                                {
                                    <th class="table-th">Actions</th>
                                }
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in reports)
                            {
                                <tr style="border-bottom:1px solid #f1f5f9;transition:background 0.15s;background:@(hoveredId == r.Id ? "#f8fafc" : "white");"
                                    @onmouseenter="() => hoveredId = r.Id"
                                    @onmouseleave="() => hoveredId = 0">
                                    <td class="table-td">
                                        <div style="font-weight:600;color:#1e293b;">
                                            @r.User?.FullName
                                        </div>
                                        <div style="font-size:0.75rem;color:#6b7280;">
                                            @r.User?.Email
                                        </div>
                                    </td>
                                    <td class="table-td">
                                        <div>@r.GeneratedAt.ToString("MMM dd, yyyy")</div>
                                        <div style="font-size:0.75rem;color:#6b7280;">
                                            @r.GeneratedAt.ToString("hh:mm tt")
                                        </div>
                                    </td>
                                    <td class="table-td" style="text-align:center;font-weight:600;">
                                        @r.TotalTasks
                                    </td>
                                    <td class="table-td" style="text-align:center;">
                                        <span style="color:#16a34a;font-weight:600;">
                                            @r.CompletedTasks
                                        </span>
                                    </td>
                                    <td class="table-td" style="text-align:center;">
                                        <span style="color:@(r.OverdueTasks > 0 ? "#dc2626" : "#16a34a");font-weight:600;">
                                            @r.OverdueTasks
                                        </span>
                                    </td>
                                    <td class="table-td">
                                        <div style="display:flex;align-items:center;gap:0.5rem;">
                                            <div style="flex:1;background:#e2e8f0;border-radius:9999px;
                                                        height:6px;min-width:60px;">
                                                <div style="background:@GetProgressColor(r.CompletionRate);
                                                            height:6px;border-radius:9999px;
                                                            width:@(r.CompletionRate)%;
                                                            transition:width 0.3s;">
                                                </div>
                                            </div>
                                            <span style="font-weight:600;font-size:0.85rem;">
                                                @r.CompletionRate%
                                            </span>
                                        </div>
                                    </td>
                                    <td class="table-td">
                                        <div style="display:flex;align-items:center;gap:0.5rem;">
                                            <div style="flex:1;background:#e2e8f0;border-radius:9999px;
                                                        height:6px;min-width:60px;">
                                                <div style="background:@GetProgressColor(r.OnTimeRate);
                                                            height:6px;border-radius:9999px;
                                                            width:@(r.OnTimeRate)%;
                                                            transition:width 0.3s;">
                                                </div>
                                            </div>
                                            <span style="font-weight:600;font-size:0.85rem;">
                                                @r.OnTimeRate%
                                            </span>
                                        </div>
                                    </td>
                                    <td class="table-td">
                                        <span class="grade-pill grade-@GetGradeClass(r.Grade)">
                                            @GetGradeIcon(r.Grade) @r.Grade
                                        </span>
                                    </td>
                                    <td class="table-td" style="text-align:center;">
                                        @if (r.BonusEligible)
                                        {
                                            <span style="color:#16a34a;font-size:1.1rem;">✅</span>
                                        }
                                        else
                                        {
                                            <span style="color:#9ca3af;font-size:1.1rem;">—</span>
                                        }
                                    </td>
                                    <td class="table-td" style="text-align:center;">
                                        @if (r.EmailSent)
                                        {
                                            <span style="color:#16a34a;font-size:0.8rem;">✉️ Sent</span>
                                        }
                                        else
                                        {
                                            <span style="color:#9ca3af;font-size:0.8rem;">—</span>
                                        }
                                    </td>
                                    @if (IsAdminOrManager)
                                    {
                                        <td class="table-td">
                                            <button class="btn-icon"
                                                    title="View detail"
                                                    @onclick="() => ShowDetail(r)">
                                                👁️
                                            </button>
                                            <button class="btn-icon"
                                                    title="Resend email"
                                                    @onclick="() => ResendEmail(r)">
                                                📧
                                            </button>
                                        </td>
                                    }
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        }
    </div>
</div>

<!-- ══ GENERATE MODAL ══════════════════════════════════════════════════ -->
@if (showGenerateModal)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal-box" @onclick:stopPropagation="true"
             style="max-width:500px;width:90%;">
            <div class="modal-header">
                <h3 style="margin:0;">⚡ Generate Task Report</h3>
                <button class="btn-icon" @onclick="CloseModal">✕</button>
            </div>

            <div class="modal-body">
                <p style="color:#6b7280;margin-top:0;">
                    Select an employee to generate their performance report based on
                    assigned tasks. The report will be emailed to them automatically.
                </p>

                <div class="form-group">
                    <label class="form-label">Select Employee</label>
                    <select class="form-input" value="@selectedUserId" @onchange="OnEmployeeSelected">
                        <option value="0">— Choose employee —</option>
                        @foreach (var u in employeeUsers)
                        {
                            <option value="@u.Id">@u.FullName (@u.Email)</option>
                        }
                    </select>
                </div>

                @if (selectedUserId > 0 && previewTasks != null)
                {
                    <!-- Task preview for selected employee -->
                    <div style="background:#f8fafc;border-radius:8px;padding:1rem;
                                margin-top:1rem;border:1px solid #e2e8f0;">
                        <div style="font-size:0.8rem;color:#6b7280;
                                    font-weight:600;margin-bottom:0.5rem;">
                            TASK PREVIEW
                        </div>
                        <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.5rem;">
                            <div class="preview-stat">
                                <span>📋 Total</span>
                                <strong>@previewTasks.Count</strong>
                            </div>
                            <div class="preview-stat">
                                <span style="color:#16a34a;">✅ Done</span>
                                <strong>@previewTasks.Count(t => t.Status == "Done")</strong>
                            </div>
                            <div class="preview-stat">
                                <span style="color:#2563eb;">🔄 In Progress</span>
                                <strong>@previewTasks.Count(t => t.Status == "In Progress")</strong>
                            </div>
                            <div class="preview-stat">
                                <span style="color:#dc2626;">⏰ Overdue</span>
                                <strong>@previewTasks.Count(t => t.Status != "Done" && t.DueDate < DateTime.Now)</strong>
                            </div>
                        </div>
                        @if (previewTasks.Count == 0)
                        {
                            <p style="color:#ef4444;font-size:0.85rem;margin:0.5rem 0 0;">
                                ⚠️ This employee has no assigned tasks. Report cannot be generated.
                            </p>
                        }
                    </div>
                }
            </div>

            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseModal">Cancel</button>
                <button class="btn-primary"
                        disabled="@(selectedUserId == 0 || isGenerating)"
                        @onclick="GenerateReport">
                    @if (isGenerating)
                    {
                        <span>⏳ Generating...</span>
                    }
                    else
                    {
                        <span>⚡ Generate & Send Email</span>
                    }
                </button>
            </div>
        </div>
    </div>
}

<!-- ══ DETAIL MODAL ════════════════════════════════════════════════════ -->
@if (showDetailModal && detailReport != null)
{
    <div class="modal-backdrop" @onclick="CloseModal">
        <div class="modal-box" @onclick:stopPropagation="true"
             style="max-width:560px;width:90%;">
            <div class="modal-header">
                <h3 style="margin:0;">📄 Report Detail</h3>
                <button class="btn-icon" @onclick="CloseModal">✕</button>
            </div>
            <div class="modal-body">
                <!-- Header info -->
                <div style="display:flex;align-items:center;gap:1rem;
                            margin-bottom:1.5rem;">
                    <div style="width:52px;height:52px;border-radius:50%;
                                background:#1e3a8a;color:white;font-size:1.3rem;
                                display:flex;align-items:center;justify-content:center;
                                font-weight:700;">
                        @detailReport.User?.FullName[0]
                    </div>
                    <div>
                        <div style="font-size:1.1rem;font-weight:700;">
                            @detailReport.User?.FullName
                        </div>
                        <div style="color:#6b7280;font-size:0.875rem;">
                            @detailReport.User?.Email
                        </div>
                        <div style="color:#9ca3af;font-size:0.8rem;">
                            Report: @detailReport.GeneratedAt.ToString("MMMM dd, yyyy hh:mm tt")
                        </div>
                    </div>
                </div>

                <!-- Grade banner -->
                <div style="text-align:center;padding:1.2rem;border-radius:10px;
                            background:@GetGradeBg(detailReport.Grade);
                            margin-bottom:1.5rem;">
                    <div style="font-size:2rem;font-weight:800;
                                color:@GetGradeTextColor(detailReport.Grade);">
                        @GetGradeIcon(detailReport.Grade) @detailReport.Grade
                    </div>
                    <div style="margin-top:0.4rem;">
                        @if (detailReport.BonusEligible)
                        {
                            <span style="background:#16a34a;color:white;padding:3px 14px;
                                         border-radius:20px;font-size:0.8rem;">
                                ✅ Bonus Eligible
                            </span>
                        }
                        else
                        {
                            <span style="background:#6b7280;color:white;padding:3px 14px;
                                         border-radius:20px;font-size:0.8rem;">
                                ❌ Not Bonus Eligible
                            </span>
                        }
                    </div>
                </div>

                <!-- Stats grid -->
                <div style="display:grid;grid-template-columns:1fr 1fr;gap:0.75rem;">
                    <div class="detail-stat">
                        <div class="detail-stat-label">Total Tasks</div>
                        <div class="detail-stat-value">@detailReport.TotalTasks</div>
                    </div>
                    <div class="detail-stat">
                        <div class="detail-stat-label">Completed</div>
                        <div class="detail-stat-value" style="color:#16a34a;">
                            @detailReport.CompletedTasks
                        </div>
                    </div>
                    <div class="detail-stat">
                        <div class="detail-stat-label">In Progress</div>
                        <div class="detail-stat-value" style="color:#2563eb;">
                            @detailReport.InProgressTasks
                        </div>
                    </div>
                    <div class="detail-stat">
                        <div class="detail-stat-label">Overdue</div>
                        <div class="detail-stat-value"
                             style="color:@(detailReport.OverdueTasks > 0 ? "#dc2626" : "#16a34a")">
                            @detailReport.OverdueTasks
                        </div>
                    </div>
                    <div class="detail-stat">
                        <div class="detail-stat-label">Completion Rate</div>
                        <div class="detail-stat-value">@detailReport.CompletionRate%</div>
                    </div>
                    <div class="detail-stat">
                        <div class="detail-stat-label">On-Time Rate</div>
                        <div class="detail-stat-value">@detailReport.OnTimeRate%</div>
                    </div>
                </div>

                <!-- Progress bars -->
                <div style="margin-top:1rem;">
                    <div style="margin-bottom:0.75rem;">
                        <div style="display:flex;justify-content:space-between;
                                    font-size:0.8rem;color:#6b7280;margin-bottom:4px;">
                            <span>Completion Rate</span>
                            <span>@detailReport.CompletionRate%</span>
                        </div>
                        <div style="background:#e2e8f0;border-radius:9999px;height:8px;">
                            <div style="background:@GetProgressColor(detailReport.CompletionRate);
                                        height:8px;border-radius:9999px;
                                        width:@(detailReport.CompletionRate)%;">
                            </div>
                        </div>
                    </div>
                    <div>
                        <div style="display:flex;justify-content:space-between;
                                    font-size:0.8rem;color:#6b7280;margin-bottom:4px;">
                            <span>On-Time Rate</span>
                            <span>@detailReport.OnTimeRate%</span>
                        </div>
                        <div style="background:#e2e8f0;border-radius:9999px;height:8px;">
                            <div style="background:@GetProgressColor(detailReport.OnTimeRate);
                                        height:8px;border-radius:9999px;
                                        width:@(detailReport.OnTimeRate)%;">
                            </div>
                        </div>
                    </div>
                </div>

                <div style="margin-top:1rem;color:#6b7280;font-size:0.8rem;">
                    📧 Email: @(detailReport.EmailSent ? $"Sent to {detailReport.EmailSentTo}" : "Not sent")
                </div>
            </div>
            <div class="modal-footer">
                <button class="btn-secondary" @onclick="CloseModal">Close</button>
                <button class="btn-primary" @onclick="() => ResendEmail(detailReport)">
                    📧 Resend Email
                </button>
            </div>
        </div>
    </div>
}

<style>
    /* Grade badges in legend */
    .grade-badge {
        padding: 0.35rem 0.9rem;
        border-radius: 9999px;
        font-size: 0.8rem;
        font-weight: 600;
    }
    .grade-excellent { background: #dcfce7; color: #16a34a; }
    .grade-average   { background: #fef9c3; color: #ca8a04; }
    .grade-warning   { background: #ffedd5; color: #ea580c; }
    .grade-serious   { background: #fee2e2; color: #dc2626; }

    /* Grade pill in table */
    .grade-pill {
        padding: 0.25rem 0.75rem;
        border-radius: 9999px;
        font-size: 0.78rem;
        font-weight: 600;
        white-space: nowrap;
    }
    .grade-pill.grade-excellent { background:#dcfce7; color:#16a34a; }
    .grade-pill.grade-average   { background:#fef9c3; color:#ca8a04; }
    .grade-pill.grade-warning   { background:#ffedd5; color:#ea580c; }
    .grade-pill.grade-serious   { background:#fee2e2; color:#dc2626; }

    .table-th {
        padding: 0.75rem 1rem;
        text-align: left;
        font-size: 0.78rem;
        font-weight: 700;
        color: #6b7280;
        text-transform: uppercase;
        letter-spacing: 0.05em;
    }
    .table-td {
        padding: 0.85rem 1rem;
        font-size: 0.875rem;
        color: #374151;
        vertical-align: middle;
    }

    .preview-stat {
        display: flex;
        justify-content: space-between;
        align-items: center;
        background: white;
        padding: 0.4rem 0.6rem;
        border-radius: 6px;
        font-size: 0.8rem;
    }

    .detail-stat {
        background: #f8fafc;
        border-radius: 8px;
        padding: 0.75rem 1rem;
    }
    .detail-stat-label {
        font-size: 0.75rem;
        color: #6b7280;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 0.04em;
    }
    .detail-stat-value {
        font-size: 1.4rem;
        font-weight: 700;
        color: #1e293b;
        margin-top: 2px;
    }

    .modal-backdrop {
        position: fixed; inset: 0;
        background: rgba(0,0,0,0.45);
        z-index: 1000;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }
    .modal-box {
        background: white;
        border-radius: 14px;
        max-height: 90vh;
        overflow-y: auto;
        box-shadow: 0 25px 50px rgba(0,0,0,0.25);
        animation: slideUp 0.2s ease;
    }
    @@keyframes slideUp {
        from { transform: translateY(20px); opacity: 0; }
        to   { transform: translateY(0);    opacity: 1; }
    }
    .modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.25rem 1.5rem;
        border-bottom: 1px solid #e2e8f0;
    }
    .modal-body    { padding: 1.5rem; }
    .modal-footer  {
        display: flex;
        justify-content: flex-end;
        gap: 0.75rem;
        padding: 1rem 1.5rem;
        border-top: 1px solid #e2e8f0;
    }

    .alert-error {
        background: #fee2e2;
        color: #991b1b;
        border: 1px solid #fca5a5;
        border-radius: 8px;
        padding: 0.75rem 1rem;
        font-size: 0.875rem;
    }
</style>

@code {
    private List<SmartBiz360.Models.TaskReport> reports = new();
    private List<SmartBiz360.Models.User> employeeUsers = new();
    private List<SmartBiz360.Models.TaskItem>? previewTasks;

    private bool isLoading = true;
    private bool showGenerateModal = false;
    private bool showDetailModal = false;
    private bool isGenerating = false;
    private string message = string.Empty;
    private bool isError = false;
    private int selectedUserId = 0;
    private int hoveredId = 0;
    private SmartBiz360.Models.TaskReport? detailReport;

    private bool IsAdminOrManager =>
        SessionService.CurrentUser?.Role == "Admin" ||
        SessionService.CurrentUser?.Role == "Manager";

    protected override async Task OnInitializedAsync()
    {
        if (SessionService.CurrentUser == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }

        await LoadData();
    }

    private async Task LoadData()
    {
        isLoading = true;
        if (IsAdminOrManager)
        {
            reports = await TaskReportService.GetAllReportsAsync();
            // Load all employee users for the dropdown
            var allUsers = await TaskService.GetUsersAsync();
            employeeUsers = allUsers
                .Where(u => u.Role == "Employee")
                .ToList();
        }
        else
        {
            // Employee sees only their own reports
            reports = await TaskReportService
                .GetReportsByUserAsync(SessionService.CurrentUser!.Id);
        }
        isLoading = false;
    }

    private void ShowGenerateModal()
    {
        selectedUserId = 0;
        previewTasks = null;
        showGenerateModal = true;
    }

    // When user changes the employee dropdown, load task preview
    private async Task OnEmployeeSelected(ChangeEventArgs e)
    {
        if (int.TryParse(e.Value?.ToString(), out int uid) && uid > 0)
        {
            selectedUserId = uid;
            var all = await TaskService.GetAllAsync();
            previewTasks = all.Where(t => t.AssignedToId == uid).ToList();
        }
        else
        {
            selectedUserId = 0;
            previewTasks = null;
        }
    }

    private async Task GenerateReport()
    {
        if (selectedUserId == 0) return;
        isGenerating = true;
        message = string.Empty;

        try
        {
            var report = await TaskReportService
                .GenerateReportAsync(selectedUserId);

            if (report == null)
            {
                isError = true;
                message = "Could not generate report. The employee may have no assigned tasks, " +
                          "or may not have an employee record.";
            }
            else
            {
                // Send email via EmailService
                var user = employeeUsers
                    .FirstOrDefault(u => u.Id == selectedUserId);
                if (user != null)
                {
                    await EmailService.SendTaskReportEmailAsync(
                        user.Email, user.FullName,
                        report.Grade,
                        report.CompletedTasks, report.TotalTasks,
                        report.CompletionRate, report.OnTimeRate,
                        report.OverdueTasks, report.BonusEligible,
                        report.GeneratedAt);
                }

                isError = false;
                message = $"✅ Report generated for {user?.FullName ?? "employee"}. " +
                          $"Grade: {report.Grade}. Email sent to {user?.Email}.";
                showGenerateModal = false;
                await LoadData();
            }
        }
        catch (Exception ex)
        {
            isError = true;
            message = $"Error generating report: {ex.Message}";
        }
        finally
        {
            isGenerating = false;
        }
    }

    private async Task ResendEmail(SmartBiz360.Models.TaskReport r)
    {
        if (r.User == null) return;
        await EmailService.SendTaskReportEmailAsync(
            r.User.Email, r.User.FullName,
            r.Grade, r.CompletedTasks, r.TotalTasks,
            r.CompletionRate, r.OnTimeRate,
            r.OverdueTasks, r.BonusEligible, r.GeneratedAt);

        isError = false;
        message = $"📧 Report email resent to {r.User.Email}.";
        showDetailModal = false;
    }

    private void ShowDetail(SmartBiz360.Models.TaskReport r)
    {
        detailReport = r;
        showDetailModal = true;
    }

    private void CloseModal()
    {
        showGenerateModal = false;
        showDetailModal = false;
    }

    // ── Helpers ───────────────────────────────────────────────────────
    private string GetProgressColor(double val) => val >= 80 ? "#16a34a"
        : val >= 60 ? "#ca8a04"
        : val >= 40 ? "#ea580c"
        : "#dc2626";

    private string GetGradeClass(string grade) => grade switch
    {
        "Excellent"       => "excellent",
        "Average"         => "average",
        "Warning"         => "warning",
        "Serious Warning" => "serious",
        _                 => "average"
    };

    private string GetGradeIcon(string grade) => grade switch
    {
        "Excellent"       => "🏆",
        "Average"         => "📊",
        "Warning"         => "⚠️",
        "Serious Warning" => "🚨",
        _                 => "📊"
    };

    private string GetGradeBg(string grade) => grade switch
    {
        "Excellent"       => "#dcfce7",
        "Average"         => "#fef9c3",
        "Warning"         => "#ffedd5",
        "Serious Warning" => "#fee2e2",
        _                 => "#f1f5f9"
    };

    private string GetGradeTextColor(string grade) => grade switch
    {
        "Excellent"       => "#16a34a",
        "Average"         => "#ca8a04",
        "Warning"         => "#ea580c",
        "Serious Warning" => "#dc2626",
        _                 => "#374151"
    };
}
