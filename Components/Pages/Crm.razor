@page "/crm"
@layout EmptyLayout
@inject CrmService CrmService
@inject SessionService SessionService
@inject NavigationManager Navigation
@inject AppDbContext Db
@inject IJSRuntime JS

<div class="dashboard-layout">

    <AppSidebar CurrentPage="crm" />

    <div class="main-content">
        <div class="topbar">
            <div>
                <h2 class="page-title">Customer Management</h2>
               
            </div>
            <div class="topbar-right">
                <button class="btn-primary" @onclick="ShowAddModal">
                    + Add Customer
                </button>
            </div>
        </div>

        <div class="filter-bar">
            <button class="filter-chip @GetFilterClass(string.Empty)"
                    @onclick="ClearFilter">
                All Customers
            </button>
            <button class="filter-chip @GetFilterClass("At Risk")"
                    @onclick="FilterAtRisk">
                At Risk
            </button>
            <button class="filter-chip @GetFilterClass("Active")"
                    @onclick="FilterActive">
                High Value
            </button>
            <input class="search-box" type="text"
                   placeholder="Filter by customer name or rep..."
                   @bind="searchTerm" @bind:event="oninput" />
        </div>

        <div class="stats-grid" style="margin-bottom:1rem;">
            <div class="stat-card">
                <div class="stat-label">Total Customers</div>
                <div class="stat-value">@customers.Count</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Retention Rate</div>
                <div class="stat-value" style="color:#16a34a;">
                    @GetRetentionRate()
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-label">At Risk Count</div>
                <div class="stat-value" style="color:#dc2626;">
                    @customers.Count(c => c.IsAtRisk)
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-label">High Value</div>
                <div class="stat-value">
                    @customers.Count(c => c.ValueTier == "High")
                </div>
            </div>
        </div>

        <div class="data-card">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Customer Name</th>
                        <th>Lifecycle Stage</th>
                        <th>Value Tier</th>
                        <th>Assigned Rep</th>
                        <th>Last Contact</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var c in FilteredCustomers)
                    {
                        <tr>
                            <td>
                                <div class="emp-name-cell">
                                    <div class="emp-avatar">
                                        @c.CompanyName[0]
                                    </div>
                                    <div>
                                        <div class="emp-name">
                                            @c.CompanyName
                                        </div>
                                        <div class="emp-email">
                                            @c.ContactName
                                        </div>
                                    </div>
                                </div>
                            </td>
                            <td>
                                <span class="badge">
                                    @c.LifecycleStage
                                </span>
                            </td>
                            <td>@c.ValueTier</td>
                            <td>
                                @(c.AssignedRep?.FullName ?? "Unassigned")
                            </td>
                            <td>
                                @c.LastContactDate.ToString("MMM dd, yyyy")
                            </td>
                            <td>
                                <button class="btn-icon"
                                        @onclick="() => ShowEditModal(c)">
                                    ✏️
                                </button>
                                <button class="btn-icon"
                                        @onclick="() => ShowLogModal(c)">
                                    📋
                                </button>
                                <button class="btn-icon"
                                        @onclick="() => DeleteCustomer(c.Id)">
                                    🗑️
                                </button>
                            </td>
                        </tr>
                    }
                    @if (!FilteredCustomers.Any())
                    {
                        <tr>
                            <td colspan="6" class="empty-row">
                                No customers found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="table-footer">
                Showing @FilteredCustomers.Count of @customers.Count customers
            </div>
        </div>
    </div>
</div>

@if (showModal)
{
    <div style="position:fixed;top:0;left:0;width:100vw;height:100vh;
                    background:rgba(0,0,0,0.5);z-index:99999;
                    display:flex;align-items:center;justify-content:center;">
        <div style="background:white;border-radius:12px;width:500px;
                        padding:2rem;box-shadow:0 8px 32px rgba(0,0,0,0.2);
                        max-height:90vh;overflow-y:auto;">
            <h3 style="margin:0 0 1rem;">
                @(isEditing ? "Edit Customer" : "Add New Customer")
            </h3>
            @if (!string.IsNullOrEmpty(modalError))
            {
                <div class="alert-error">@modalError</div>
            }
            <div class="form-group">
                <label>Company Name</label>
                <input @bind="current.CompanyName" placeholder="Acme Corp"
                       style="width:100%;padding:0.6rem;border:1px solid #ddd;
                                  border-radius:6px;box-sizing:border-box;" />
            </div>
            <div class="form-group">
                <label>Contact Name</label>
                <input @bind="current.ContactName" placeholder="John Smith"
                       style="width:100%;padding:0.6rem;border:1px solid #ddd;
                                  border-radius:6px;box-sizing:border-box;" />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" @bind="current.Email"
                       placeholder="contact@acme.com"
                       style="width:100%;padding:0.6rem;border:1px solid #ddd;
                                  border-radius:6px;box-sizing:border-box;" />
            </div>
            <div class="form-group">
                <label>Phone</label>
                <input @bind="current.Phone" placeholder="+92 300 0000000"
                       style="width:100%;padding:0.6rem;border:1px solid #ddd;
                                  border-radius:6px;box-sizing:border-box;" />
            </div>
            <div class="form-group">
                <label>Lifecycle Stage</label>
                <select @bind="current.LifecycleStage"
                        style="width:100%;padding:0.6rem;border:1px solid #ddd;
                                   border-radius:6px;box-sizing:border-box;">
                    <option>Lead</option>
                    <option>Active</option>
                    <option>At Risk</option>
                    <option>Churned</option>
                </select>
            </div>
            <div class="form-group">
                <label>Value Tier</label>
                <select @bind="current.ValueTier"
                        style="width:100%;padding:0.6rem;border:1px solid #ddd;
                                   border-radius:6px;box-sizing:border-box;">
                    <option>High</option>
                    <option>Medium</option>
                    <option>Low</option>
                </select>
            </div>
            <div class="form-group">
                <label>Last Contact Date</label>
                <input type="date" @bind="current.LastContactDate"
                       style="width:100%;padding:0.6rem;border:1px solid #ddd;
                                  border-radius:6px;box-sizing:border-box;" />
            </div>
            <div style="display:flex;justify-content:flex-end;
                            gap:0.75rem;margin-top:1.5rem;">
                <button class="btn-secondary" @onclick="CloseModal">
                    Cancel
                </button>
                <button class="btn-primary" @onclick="SaveCustomer">
                    @(isEditing ? "Update" : "Add Customer")
                </button>
            </div>
        </div>
    </div>
}

@if (showLogModal && selectedCustomer != null)
{
    <div style="position:fixed;top:0;left:0;width:100vw;height:100vh;
                    background:rgba(0,0,0,0.5);z-index:99999;
                    display:flex;align-items:center;justify-content:center;">
        <div style="background:white;border-radius:12px;width:580px;
                        padding:2rem;box-shadow:0 8px 32px rgba(0,0,0,0.2);
                        max-height:90vh;overflow-y:auto;">
            <div style="display:flex;justify-content:space-between;
                            align-items:center;margin-bottom:1rem;">
                <h3 style="margin:0;">
                    Interaction Log — @selectedCustomer.CompanyName
                </h3>
                <button class="btn-secondary" @onclick="CloseLogModal">
                    ✕
                </button>
            </div>
            <div style="background:#f8fafc;border-radius:8px;
                            padding:1rem;margin-bottom:1rem;">
                <div style="font-weight:600;margin-bottom:0.75rem;
                                font-size:0.9rem;">
                    + Add Interaction
                </div>
                <div style="display:grid;grid-template-columns:1fr 1fr;
                                gap:0.75rem;margin-bottom:0.75rem;">
                    <div>
                        <label style="font-size:0.8rem;font-weight:500;">
                            Type
                        </label>
                        <select @bind="newLog.Type"
                                style="width:100%;padding:0.5rem;
                                           border:1px solid #ddd;
                                           border-radius:6px;
                                           box-sizing:border-box;">
                            <option>Call</option>
                            <option>Email</option>
                            <option>Meeting</option>
                        </select>
                    </div>
                    <div>
                        <label style="font-size:0.8rem;font-weight:500;">
                            Date
                        </label>
                        <input type="date" @bind="newLog.InteractionDate"
                               style="width:100%;padding:0.5rem;
                                          border:1px solid #ddd;
                                          border-radius:6px;
                                          box-sizing:border-box;" />
                    </div>
                </div>
                <div style="margin-bottom:0.75rem;">
                    <label style="font-size:0.8rem;font-weight:500;">
                        Notes
                    </label>
                    <input @bind="newLog.Notes"
                           placeholder="Discuss renewal proposal..."
                           style="width:100%;padding:0.5rem;
                                      border:1px solid #ddd;border-radius:6px;
                                      box-sizing:border-box;" />
                </div>
                <button class="btn-primary" @onclick="SaveInteraction">
                    Add Interaction
                </button>
            </div>
            <div style="font-weight:600;margin-bottom:0.75rem;">History</div>
            @if (!interactions.Any())
            {
                <p style="color:#9ca3af;font-size:0.85rem;">
                    No interactions logged yet.
                </p>
            }
            @foreach (var log in interactions
                    .OrderByDescending(l => l.InteractionDate))
            {
                <div style="border:1px solid #f3f4f6;border-radius:8px;
                                    padding:0.75rem;margin-bottom:0.5rem;">
                    <div style="display:flex;justify-content:space-between;
                                        align-items:center;">
                        <div style="display:flex;gap:0.5rem;
                                            align-items:center;">
                            <span class="badge badge-lead">@log.Type</span>
                            <span style="font-weight:500;font-size:0.9rem;">
                                @log.InteractionDate.ToString("MMM dd, yyyy")
                            </span>
                        </div>
                        <button class="btn-icon"
                                @onclick="() => DeleteInteraction(log.Id)">
                            🗑️
                        </button>
                    </div>
                    <div style="color:#6b7280;font-size:0.85rem;
                                        margin-top:0.4rem;">
                        @log.Notes
                    </div>
                    <div style="color:#9ca3af;font-size:0.75rem;
                                        margin-top:0.25rem;">
                        Logged by: @log.User.FullName
                    </div>
                </div>
            }
            <div style="margin-top:1rem;text-align:right;">
                <button class="btn-primary" @onclick="UpdateLastContact">
                    ✅ Mark Contacted Today
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<Customer> customers = new();
    private List<User> reps = new();
    private string searchTerm = "";
    private string lifecycleFilter = "";
    private bool showModal = false;
    private bool isEditing = false;
    private string modalError = "";
    private Customer current = new();
    private bool showLogModal = false;
    private Customer? selectedCustomer;
    private List<InteractionLog> interactions = new();
    private InteractionLog newLog = new();

    private string GetFilterClass(string filter)
        => lifecycleFilter == filter ? "active" : "";

    private void ClearFilter() => lifecycleFilter = "";
    private void FilterAtRisk() => lifecycleFilter = "At Risk";
    private void FilterActive() => lifecycleFilter = "Active";

    private string GetRetentionRate()
    {
        if (customers.Count == 0) return "0%";
        double rate = customers.Count(c =>
            c.LifecycleStage == "Active") * 100.0 / customers.Count;
        return $"{rate:F1}%";
    }

    private List<Customer> FilteredCustomers => customers
        .Where(c =>
            (string.IsNullOrEmpty(searchTerm) ||
             c.CompanyName.Contains(searchTerm,
                 StringComparison.OrdinalIgnoreCase) ||
             c.ContactName.Contains(searchTerm,
                 StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(lifecycleFilter) ||
             c.LifecycleStage == lifecycleFilter))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        if (SessionService.CurrentUser == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }
        if (SessionService.CurrentUser.Role == "Employee")
        {
            Navigation.NavigateTo("/dashboard");
            return;
        }
        await LoadData();
    }

    private async Task LoadData()
    {
        await CrmService.CheckAtRiskAsync();
        customers = await CrmService.GetAllAsync();
        reps = await CrmService.GetSalesRepsAsync();
    }

    private void ShowAddModal()
    {
        isEditing = false;
        current = new Customer { LastContactDate = DateTime.Today };
        modalError = "";
        showModal = true;
    }

    private void ShowEditModal(Customer c)
    {
        isEditing = true;
        current = c;
        modalError = "";
        showModal = true;
    }

    private static bool IsValidEmail(string email)
    {
        try
        {
            var addr = new System.Net.Mail.MailAddress(email.Trim());
            return addr.Address == email.Trim();
        }
        catch { return false; }
    }

    private static bool IsValidPhone(string phone)
    {
        // Accepts formats: +92 300 0000000 / 03001234567 / +1-800-555-0199
        var digits = new string(phone.Where(char.IsDigit).ToArray());
        return digits.Length >= 7 && digits.Length <= 15;
    }

    private async Task SaveCustomer()
    {
        modalError = "";

        if (string.IsNullOrWhiteSpace(current.CompanyName))
        { modalError = "Company name is required."; return; }

        if (current.CompanyName.Trim().Length < 2)
        { modalError = "Company name must be at least 2 characters."; return; }

        if (string.IsNullOrWhiteSpace(current.ContactName))
        { modalError = "Contact name is required."; return; }

        if (!string.IsNullOrWhiteSpace(current.Email) &&
            !IsValidEmail(current.Email))
        { modalError = "Please enter a valid email address."; return; }

        if (!string.IsNullOrWhiteSpace(current.Phone) &&
            !IsValidPhone(current.Phone))
        { modalError = "Phone number must be 7–15 digits (e.g. +92 300 0000000)."; return; }

        if (current.LastContactDate > DateTime.Today)
        { modalError = "Last contact date cannot be in the future."; return; }

        // Duplicate company name check (on add only)
        if (!isEditing)
        {
            bool exists = customers.Any(c =>
                c.CompanyName.Equals(current.CompanyName.Trim(),
                    StringComparison.OrdinalIgnoreCase));
            if (exists)
            { modalError = "A customer with this company name already exists."; return; }
        }

        if (isEditing)
            await CrmService.UpdateAsync(current);
        else
            await CrmService.CreateAsync(current);
        await LoadData();
        CloseModal();
    }

    private async Task DeleteCustomer(int id)
    {
        bool confirmed = await JS.InvokeAsync<bool>(
            "confirmDelete",
            "Are you sure you want to delete this customer?");
        if (!confirmed) return;
        await CrmService.DeleteAsync(id);
        await LoadData();
    }

    private void CloseModal() => showModal = false;

    private async Task ShowLogModal(Customer c)
    {
        selectedCustomer = c;
        newLog = new InteractionLog
        {
            CustomerId = c.Id,
            Type = "Call",
            InteractionDate = DateTime.Today
        };
        interactions = await Db.InteractionLogs
            .Include(l => l.User)
            .Where(l => l.CustomerId == c.Id)
            .ToListAsync();
        showLogModal = true;
    }

    private async Task SaveInteraction()
    {
        if (string.IsNullOrWhiteSpace(newLog.Notes)) return;
        newLog.CustomerId = selectedCustomer!.Id;
        newLog.UserId = SessionService.CurrentUser!.Id;
        Db.InteractionLogs.Add(newLog);
        await Db.SaveChangesAsync();
        interactions = await Db.InteractionLogs
            .Include(l => l.User)
            .Where(l => l.CustomerId == selectedCustomer.Id)
            .ToListAsync();
        newLog = new InteractionLog
        {
            CustomerId = selectedCustomer.Id,
            Type = "Call",
            InteractionDate = DateTime.Today
        };
    }

    private async Task DeleteInteraction(int id)
    {
        bool confirmed = await JS.InvokeAsync<bool>(
            "confirmDelete",
            "Are you sure you want to delete this interaction?");
        if (!confirmed) return;
        var log = await Db.InteractionLogs.FindAsync(id);
        if (log != null)
        {
            Db.InteractionLogs.Remove(log);
            await Db.SaveChangesAsync();
            interactions = await Db.InteractionLogs
                .Include(l => l.User)
                .Where(l => l.CustomerId == selectedCustomer!.Id)
                .ToListAsync();
        }
    }

    private async Task UpdateLastContact()
    {
        if (selectedCustomer == null) return;
        selectedCustomer.LastContactDate = DateTime.Today;
        selectedCustomer.IsAtRisk = false;
        Db.Customers.Update(selectedCustomer);
        await Db.SaveChangesAsync();
        await LoadData();
        CloseLogModal();
    }

    private void CloseLogModal() => showLogModal = false;
}