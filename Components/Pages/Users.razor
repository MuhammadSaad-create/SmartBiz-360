@page "/users"
@layout EmptyLayout
@inject AuthService AuthService
@inject SessionService SessionService
@inject NavigationManager Navigation
@inject AppDbContext Db
@inject EmailService EmailService
@inject IJSRuntime JS

<div class="dashboard-layout">

    <AppSidebar CurrentPage="users" />

    <div class="main-content">
        <div class="topbar">
            <div>
                <h2 class="page-title">User & Role Management</h2>
             
            </div>
            <div class="topbar-right">
                <button class="btn-secondary"
                        @onclick="SyncAllUsersToEmployees">
                    🔄 Sync Employees
                </button>
                <button class="btn-primary" @onclick="ShowAddModal">
                    + Add User
                </button>
            </div>
        </div>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert-success">@message</div>
        }

        <div class="stats-grid" style="margin-bottom:1rem;">
            <div class="stat-card">
                <div class="stat-label">Total Users</div>
                <div class="stat-value">@users.Count</div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Admins</div>
                <div class="stat-value" style="color:#2563eb;">
                    @users.Count(u => u.Role == "Admin")
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Managers</div>
                <div class="stat-value" style="color:#ca8a04;">
                    @users.Count(u => u.Role == "Manager")
                </div>
            </div>
            <div class="stat-card">
                <div class="stat-label">Employees</div>
                <div class="stat-value" style="color:#16a34a;">
                    @users.Count(u => u.Role == "Employee")
                </div>
            </div>
        </div>

        <div class="filter-bar">
            <input class="search-box" type="text"
                   placeholder="Search users..."
                   value="@searchTerm"
                   @oninput="OnSearchInput" />
            <select class="filter-select" @bind="roleFilter"
                    @bind:after="StateHasChanged">
                <option value="">All Roles</option>
                <option value="Admin">Admin</option>
                <option value="Manager">Manager</option>
                <option value="Employee">Employee</option>
            </select>
        </div>

        <div class="data-card">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>User</th>
                        <th>Email</th>
                        <th>Role</th>
                        <th>Status</th>
                        <th>Created</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in FilteredUsers)
                    {
                        <tr>
                            <td>
                                <div class="emp-name-cell">
                                    <div class="emp-avatar">
                                        @u.FullName[0]
                                    </div>
                                    <div class="emp-name">
                                        @u.FullName
                                    </div>
                                </div>
                            </td>
                            <td>@u.Email</td>
                            <td>
                                <span class="badge badge-role-@u.Role
                                        .ToLower()">
                                    @u.Role
                                </span>
                            </td>
                            <td>
                                <span class="badge @(u.IsActive ?
                                                                          "badge-active" : "badge-offline")">
                                @(u.IsActive ? "Active" : "Inactive")
                            </span>
                        </td>
                        <td>@u.CreatedAt.ToString("MMM dd, yyyy")</td>
                        <td>
                            <button class="btn-icon"
                                    @onclick="() => ShowEditModal(u)">
                                ✏️
                            </button>
                            <button class="btn-icon"
                                    @onclick="() => ToggleActive(u)">
                                @(u.IsActive ? "🔒" : "🔓")
                            </button>
                        </td>
                    </tr>
                                        }
                    @if (!FilteredUsers.Any())
                    {
                        <tr>
                            <td colspan="6" class="empty-row">
                                No users found.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
            <div class="table-footer">
                Showing @FilteredUsers.Count of @users.Count users
            </div>
        </div>
    </div>
</div>

@if (showModal)
{
    <div style="position:fixed;top:0;left:0;width:100vw;
                    height:100vh;background:rgba(0,0,0,0.5);
                    z-index:99999;display:flex;align-items:center;
                    justify-content:center;">
        <div style="background:white;border-radius:12px;
                        width:460px;padding:2rem;
                        box-shadow:0 8px 32px rgba(0,0,0,0.2);">
            <h3 style="margin:0 0 1rem;">
                @(isEditing ? "Edit User" : "Add New User")
            </h3>

            @if (!string.IsNullOrEmpty(modalError))
            {
                <div class="alert-error">@modalError</div>
            }

            <div class="form-group">
                <label>Full Name</label>
                <input @bind="current.FullName"
                       placeholder="John Doe"
                       style="width:100%;padding:0.6rem;
                                  border:1px solid #ddd;
                                  border-radius:6px;
                                  box-sizing:border-box;" />
            </div>
            <div class="form-group">
                <label>Email</label>
                <input type="email" @bind="current.Email"
                       placeholder="john@company.com"
                       disabled="@isEditing"
                       style="width:100%;padding:0.6rem;
                                  border:1px solid #ddd;border-radius:6px;
                                  box-sizing:border-box;
                                  @(isEditing ? "background:#f3f4f6;" : "")" />
            </div>
            @if (!isEditing)
            {
                <div class="form-group">
                    <label>Password</label>
                    <input type="password" @bind="newPassword"
                           placeholder="Min 8 characters"
                           style="width:100%;padding:0.6rem;
                                          border:1px solid #ddd;
                                          border-radius:6px;
                                          box-sizing:border-box;" />
                </div>
            }
            <div class="form-group">
                <label>Role</label>
                <select @bind="current.Role"
                        style="width:100%;padding:0.6rem;
                                   border:1px solid #ddd;border-radius:6px;
                                   box-sizing:border-box;">
                    <option>Admin</option>
                    <option>Manager</option>
                    <option>Employee</option>
                </select>
            </div>

            <div style="display:flex;justify-content:flex-end;
                            gap:0.75rem;margin-top:1.5rem;">
                <button class="btn-secondary" @onclick="CloseModal">
                    Cancel
                </button>
                <button class="btn-primary" @onclick="SaveUser">
                    @(isEditing ? "Update" : "Add User")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<User> users = new();
    private string searchTerm = "";
    private string roleFilter = "";
    private bool showModal = false;
    private bool isEditing = false;
    private string modalError = "";
    private string message = "";
    private string newPassword = "";
    private User current = new();

    private List<User> FilteredUsers => users
        .Where(u =>
            (string.IsNullOrEmpty(searchTerm) ||
             u.FullName.Contains(searchTerm,
                 StringComparison.OrdinalIgnoreCase) ||
             u.Email.Contains(searchTerm,
                 StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(roleFilter) ||
             u.Role == roleFilter))
        .ToList();

    private void OnSearchInput(ChangeEventArgs e)
    {
        searchTerm = e.Value?.ToString() ?? string.Empty;
        StateHasChanged();
    }

    protected override async Task OnInitializedAsync()
    {
        if (SessionService.CurrentUser == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }
        if (SessionService.CurrentUser.Role != "Admin")
        {
            Navigation.NavigateTo("/dashboard");
            return;
        }
        await LoadData();
    }

    private async Task LoadData()
    {
        users = await Db.Users.ToListAsync();
    }

    private void ShowAddModal()
    {
        isEditing = false;
        current = new User { Role = "Employee", IsActive = true };
        newPassword = "";
        modalError = "";
        showModal = true;
    }

    private void ShowEditModal(User u)
    {
        isEditing = true;
        current = u;
        modalError = "";
        showModal = true;
    }

    private static bool IsValidEmail(string email)
    {
        try
        {
            var addr = new System.Net.Mail.MailAddress(email.Trim());
            return addr.Address == email.Trim();
        }
        catch { return false; }
    }

    private async Task SaveUser()
    {
        modalError = "";

        if (string.IsNullOrWhiteSpace(current.FullName))
        { modalError = "Full name is required."; return; }

        if (current.FullName.Trim().Length < 2)
        { modalError = "Full name must be at least 2 characters."; return; }

        if (string.IsNullOrWhiteSpace(current.Email))
        { modalError = "Email address is required."; return; }

        if (!IsValidEmail(current.Email))
        { modalError = "Please enter a valid email address (e.g. user@domain.com)."; return; }

        if (isEditing)
        {
            bool emailTaken = await Db.Users
                .AnyAsync(u => u.Email == current.Email.Trim() && u.Id != current.Id);
            if (emailTaken)
            { modalError = "Another user with this email already exists."; return; }

            Db.Users.Update(current);
            await Db.SaveChangesAsync();
            await CreateEmployeeRecordIfMissing(current);
            message = "User updated successfully!";
        }
        else
        {
            if (string.IsNullOrWhiteSpace(newPassword))
            { modalError = "Password is required."; return; }

            if (newPassword.Length < 8)
            { modalError = "Password must be at least 8 characters."; return; }

            if (!newPassword.Any(char.IsUpper))
            { modalError = "Password must contain at least one uppercase letter."; return; }

            if (!newPassword.Any(char.IsDigit))
            { modalError = "Password must contain at least one number."; return; }

            bool success = await AuthService.RegisterAsync(
                current.FullName,
                current.Email,
                newPassword,
                current.Role);

            if (!success)
            { modalError = "Email already exists."; return; }

            if (current.Role == "Employee" ||
                current.Role == "Manager")
            {
                var newUser = await Db.Users
                    .FirstOrDefaultAsync(
                        u => u.Email == current.Email);

                if (newUser != null)
                {
                    Db.Employees.Add(new Employee
                    {
                        UserId = newUser.Id,
                        Department = "General",
                        Position = current.Role,
                        EmploymentStatus = "Active",
                        JoinDate = DateTime.Today,
                        MonitoringConsent = false
                    });
                    await Db.SaveChangesAsync();
                }
            }
            // Send welcome email
            await EmailService.SendWelcomeEmailAsync(
                current.Email,
                current.FullName,
                newPassword);
            message = "User created successfully!";
        }

        await LoadData();
        CloseModal();
    }

    private async Task ToggleActive(User u)
    {
        u.IsActive = !u.IsActive;
        Db.Users.Update(u);
        await Db.SaveChangesAsync();
        await CreateEmployeeRecordIfMissing(u);
        message = $"User {(u.IsActive ? "activated" : "deactivated")}!";
        await LoadData();
    }

    private async Task CreateEmployeeRecordIfMissing(User u)
    {
        if (u.Role != "Employee" && u.Role != "Manager") return;

        bool exists = await Db.Employees
            .AnyAsync(e => e.UserId == u.Id);

        if (!exists)
        {
            Db.Employees.Add(new Employee
            {
                UserId = u.Id,
                Department = "General",
                Position = u.Role,
                EmploymentStatus = "Active",
                JoinDate = DateTime.Today,
                MonitoringConsent = false
            });
            await Db.SaveChangesAsync();
        }
    }

    private async Task SyncAllUsersToEmployees()
    {
        var allUsers = await Db.Users
            .Where(u => u.Role == "Employee" ||
                        u.Role == "Manager")
            .ToListAsync();

        foreach (var u in allUsers)
        {
            bool exists = await Db.Employees
                .AnyAsync(e => e.UserId == u.Id);

            if (!exists)
            {
                Db.Employees.Add(new Employee
                {
                    UserId = u.Id,
                    Department = "General",
                    Position = u.Role,
                    EmploymentStatus = "Active",
                    JoinDate = DateTime.Today,
                    MonitoringConsent = false
                });
            }
        }

        await Db.SaveChangesAsync();
        message = "Sync complete! All users synced to employees.";
        await LoadData();
    }

    private void CloseModal() => showModal = false;
}