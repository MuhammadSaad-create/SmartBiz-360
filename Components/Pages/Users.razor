@page "/users"
@layout EmptyLayout
@inject AuthService AuthService
@inject SessionService SessionService
@inject NavigationManager Navigation
@inject AppDbContext Db

<div style="display:flex;min-height:100vh;background:#f8fafc;">

    @if (SessionService.IsLoggedIn)
    {
        <div style="width:220px;background:#1e293b;color:white;padding:1.5rem 1rem;flex-shrink:0;">
            <div style="font-size:1.1rem;font-weight:700;margin-bottom:2rem;">SmartBiz 360</div>
            <nav style="display:flex;flex-direction:column;gap:0.5rem;">
                <a href="/dashboard" style="color:#cbd5e1;text-decoration:none;padding:0.6rem 0.75rem;border-radius:6px;">⊞ Dashboard</a>
                <a href="/employees" style="color:#cbd5e1;text-decoration:none;padding:0.6rem 0.75rem;border-radius:6px;">👥 Employees</a>
                @if (SessionService.IsAdmin || SessionService.IsManager)
                {
                    <a href="/crm" style="color:#cbd5e1;text-decoration:none;padding:0.6rem 0.75rem;border-radius:6px;">🤝 CRM</a>
                }
                @if (SessionService.IsAdmin)
                {
                    <a href="/users" style="color:white;text-decoration:none;padding:0.6rem 0.75rem;border-radius:6px;background:#334155;">👤 Users</a>
                }
            </nav>
            <div style="margin-top:auto;padding-top:2rem;font-size:0.8rem;color:#94a3b8;">
                @SessionService.CurrentUser?.FullName<br />
                @SessionService.CurrentUser?.Role
                <br />
                <a href="/login" style="color:#f87171;">Logout</a>
            </div>
        </div>
    }

    <div style="flex:1;padding:2rem;">
        <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:1.5rem;">
            <div>
                <h2 style="margin:0;font-size:1.4rem;font-weight:700;">User & Role Management</h2>
                <p style="margin:0;color:#6b7280;font-size:0.9rem;">Manage system users, roles, and account status.</p>
            </div>
            <button @onclick="ShowAddModal"
                    style="background:#2563eb;color:white;border:none;padding:0.6rem 1.2rem;border-radius:8px;cursor:pointer;font-weight:600;">
                + Add User
            </button>
        </div>

        @if (!string.IsNullOrEmpty(message))
        {
            <div style="background:#dcfce7;color:#166534;padding:0.75rem 1rem;border-radius:8px;margin-bottom:1rem;">
                @message
            </div>
        }

        <!-- Stats -->
        <div style="display:grid;grid-template-columns:repeat(4,1fr);gap:1rem;margin-bottom:1.5rem;">
            <div style="background:white;padding:1rem;border-radius:10px;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
                <div style="font-size:0.8rem;color:#6b7280;">Total Users</div>
                <div style="font-size:1.8rem;font-weight:700;">@users.Count</div>
            </div>
            <div style="background:white;padding:1rem;border-radius:10px;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
                <div style="font-size:0.8rem;color:#6b7280;">Admins</div>
                <div style="font-size:1.8rem;font-weight:700;color:#2563eb;">@users.Count(u => u.Role == "Admin")</div>
            </div>
            <div style="background:white;padding:1rem;border-radius:10px;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
                <div style="font-size:0.8rem;color:#6b7280;">Managers</div>
                <div style="font-size:1.8rem;font-weight:700;color:#ca8a04;">@users.Count(u => u.Role == "Manager")</div>
            </div>
            <div style="background:white;padding:1rem;border-radius:10px;box-shadow:0 1px 4px rgba(0,0,0,0.08);">
                <div style="font-size:0.8rem;color:#6b7280;">Employees</div>
                <div style="font-size:1.8rem;font-weight:700;color:#16a34a;">@users.Count(u => u.Role == "Employee")</div>
            </div>
        </div>

        <!-- Search & Filter -->
        <div style="display:flex;gap:0.75rem;margin-bottom:1rem;">
            <input type="text" placeholder="Search users..."
                   @bind="searchTerm" @bind:event="oninput"
                   style="padding:0.5rem 1rem;border:1px solid #e2e8f0;border-radius:8px;width:260px;" />
            <select @bind="roleFilter"
                    style="padding:0.5rem 1rem;border:1px solid #e2e8f0;border-radius:8px;">
                <option value="">All Roles</option>
                <option value="Admin">Admin</option>
                <option value="Manager">Manager</option>
                <option value="Employee">Employee</option>
            </select>
        </div>

        <!-- Table -->
        <div style="background:white;border-radius:10px;box-shadow:0 1px 4px rgba(0,0,0,0.08);overflow:hidden;">
            <table style="width:100%;border-collapse:collapse;">
                <thead style="background:#f8fafc;">
                    <tr>
                        <th style="padding:0.75rem 1rem;text-align:left;font-size:0.8rem;color:#6b7280;font-weight:600;">USER</th>
                        <th style="padding:0.75rem 1rem;text-align:left;font-size:0.8rem;color:#6b7280;font-weight:600;">EMAIL</th>
                        <th style="padding:0.75rem 1rem;text-align:left;font-size:0.8rem;color:#6b7280;font-weight:600;">ROLE</th>
                        <th style="padding:0.75rem 1rem;text-align:left;font-size:0.8rem;color:#6b7280;font-weight:600;">STATUS</th>
                        <th style="padding:0.75rem 1rem;text-align:left;font-size:0.8rem;color:#6b7280;font-weight:600;">CREATED</th>
                        <th style="padding:0.75rem 1rem;text-align:left;font-size:0.8rem;color:#6b7280;font-weight:600;">ACTIONS</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var u in FilteredUsers)
                    {
                        <tr style="border-top:1px solid #f1f5f9;">
                            <td style="padding:0.75rem 1rem;">
                                <div style="display:flex;align-items:center;gap:0.6rem;">
                                    <div style="width:34px;height:34px;border-radius:50%;background:#2563eb;color:white;display:flex;align-items:center;justify-content:center;font-weight:700;font-size:0.9rem;">
                                        @u.FullName[0]
                                    </div>
                                    <span style="font-weight:500;">@u.FullName</span>
                                </div>
                            </td>
                            <td style="padding:0.75rem 1rem;color:#6b7280;font-size:0.9rem;">@u.Email</td>
                            <td style="padding:0.75rem 1rem;">
                                <span style="padding:0.25rem 0.7rem;border-radius:20px;font-size:0.78rem;font-weight:600;
                                    background:@(u.Role=="Admin"?"#dbeafe":u.Role=="Manager"?"#fef9c3":"#dcfce7");
                                    color:@(u.Role=="Admin"?"#1d4ed8":u.Role=="Manager"?"#854d0e":"#166534");">
                                    @u.Role
                                </span>
                            </td>
                            <td style="padding:0.75rem 1rem;">
                                <span style="padding:0.25rem 0.7rem;border-radius:20px;font-size:0.78rem;font-weight:600;
                                    background:@(u.IsActive?"#dcfce7":"#fee2e2");
                                    color:@(u.IsActive?"#166534":"#991b1b");">
                                    @(u.IsActive ? "Active" : "Inactive")
                                </span>
                            </td>
                            <td style="padding:0.75rem 1rem;color:#6b7280;font-size:0.9rem;">@u.CreatedAt.ToString("MMM dd, yyyy")</td>
                            <td style="padding:0.75rem 1rem;">
                                <div style="display:flex;gap:0.4rem;">
                                    <button @onclick="() => ShowEditModal(u)"
                                            style="border:1px solid #e2e8f0;background:white;padding:0.3rem 0.6rem;border-radius:6px;cursor:pointer;">✏️</button>
                                    <button @onclick="() => ToggleActive(u)"
                                            style="border:1px solid #e2e8f0;background:white;padding:0.3rem 0.6rem;border-radius:6px;cursor:pointer;">
                                        @(u.IsActive ? "🔒" : "🔓")
                                    </button>
                                </div>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (showModal)
{
    <div style="position:fixed;top:0;left:0;width:100vw;height:100vh;background:rgba(0,0,0,0.5);z-index:9999;display:flex;align-items:center;justify-content:center;">
        <div style="background:white;border-radius:12px;width:440px;padding:2rem;box-shadow:0 8px 32px rgba(0,0,0,0.2);">
            <h3 style="margin:0 0 1.5rem;">@(isEditing ? "Edit User" : "Add New User")</h3>

            @if (!string.IsNullOrEmpty(modalError))
            {
                <div style="background:#fee2e2;color:#991b1b;padding:0.6rem 1rem;border-radius:6px;margin-bottom:1rem;font-size:0.9rem;">
                    @modalError
                </div>
            }

            <div style="margin-bottom:1rem;">
                <label style="display:block;font-size:0.85rem;font-weight:600;margin-bottom:0.4rem;">Full Name</label>
                <input @bind="current.FullName" placeholder="John Doe"
                       style="width:100%;padding:0.6rem;border:1px solid #ddd;border-radius:6px;box-sizing:border-box;" />
            </div>
            <div style="margin-bottom:1rem;">
                <label style="display:block;font-size:0.85rem;font-weight:600;margin-bottom:0.4rem;">Email</label>
                <input type="email" @bind="current.Email" placeholder="john@company.com"
                       disabled="@isEditing"
                       style="width:100%;padding:0.6rem;border:1px solid #ddd;border-radius:6px;box-sizing:border-box;@(isEditing?"background:#f3f4f6;":"")" />
            </div>
            @if (!isEditing)
            {
                <div style="margin-bottom:1rem;">
                    <label style="display:block;font-size:0.85rem;font-weight:600;margin-bottom:0.4rem;">Password</label>
                    <input type="password" @bind="newPassword" placeholder="Min 8 characters"
                           style="width:100%;padding:0.6rem;border:1px solid #ddd;border-radius:6px;box-sizing:border-box;" />
                </div>
            }
            <div style="margin-bottom:1.5rem;">
                <label style="display:block;font-size:0.85rem;font-weight:600;margin-bottom:0.4rem;">Role</label>
                <select @bind="current.Role"
                        style="width:100%;padding:0.6rem;border:1px solid #ddd;border-radius:6px;box-sizing:border-box;">
                    <option>Admin</option>
                    <option>Manager</option>
                    <option>Employee</option>
                </select>
            </div>

            <div style="display:flex;justify-content:flex-end;gap:0.75rem;">
                <button @onclick="CloseModal"
                        style="padding:0.6rem 1.2rem;border:1px solid #ddd;background:white;border-radius:8px;cursor:pointer;">
                    Cancel
                </button>
                <button @onclick="SaveUser"
                        style="padding:0.6rem 1.2rem;background:#2563eb;color:white;border:none;border-radius:8px;cursor:pointer;font-weight:600;">
                    @(isEditing ? "Update" : "Add User")
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<User> users = new();
    private string searchTerm = "";
    private string roleFilter = "";
    private bool showModal = false;
    private bool isEditing = false;
    private string modalError = "";
    private string message = "";
    private string newPassword = "";
    private User current = new();

    private List<User> FilteredUsers => users
        .Where(u =>
            (string.IsNullOrEmpty(searchTerm) ||
             u.FullName.Contains(searchTerm, StringComparison.OrdinalIgnoreCase) ||
             u.Email.Contains(searchTerm, StringComparison.OrdinalIgnoreCase)) &&
            (string.IsNullOrEmpty(roleFilter) || u.Role == roleFilter))
        .ToList();

    protected override async Task OnInitializedAsync()
    {
        if (!SessionService.IsLoggedIn)
        {
            Navigation.NavigateTo("/login");
            return;
        }
        if (!SessionService.IsAdmin)
        {
            Navigation.NavigateTo("/dashboard");
            return;
        }
        await LoadData();
    }

    private async Task LoadData()
    {
        users = await Db.Users.ToListAsync();
    }

    private void ShowAddModal()
    {
        isEditing = false;
        current = new User { Role = "Employee", IsActive = true };
        newPassword = "";
        modalError = "";
        showModal = true;
    }

    private void ShowEditModal(User u)
    {
        isEditing = true;
        current = u;
        modalError = "";
        showModal = true;
    }

    private async Task SaveUser()
    {
        modalError = "";
        if (string.IsNullOrWhiteSpace(current.FullName) || string.IsNullOrWhiteSpace(current.Email))
        {
            modalError = "Name and email are required.";
            return;
        }

        if (isEditing)
        {
            Db.Users.Update(current);
            await Db.SaveChangesAsync();
            message = "User updated successfully!";
        }
        else
        {
            if (string.IsNullOrWhiteSpace(newPassword) || newPassword.Length < 8)
            {
                modalError = "Password must be at least 8 characters.";
                return;
            }
            bool success = await AuthService.RegisterAsync(current.FullName, current.Email, newPassword, current.Role);
            if (!success)
            {
                modalError = "Email already exists.";
                return;
            }

            if (current.Role == "Employee" || current.Role == "Manager")
            {
                var newUser = await Db.Users.FirstOrDefaultAsync(u => u.Email == current.Email);
                if (newUser != null)
                {
                    Db.Employees.Add(new Employee
                    {
                        UserId = newUser.Id,
                        Department = "General",
                        Position = current.Role,
                        EmploymentStatus = "Active",
                        JoinDate = DateTime.Today
                    });
                    await Db.SaveChangesAsync();
                }
            }
            message = "User created successfully!";
        }

        await LoadData();
        CloseModal();
    }

    private async Task ToggleActive(User u)
    {
        u.IsActive = !u.IsActive;
        Db.Users.Update(u);
        await Db.SaveChangesAsync();
        message = $"User {(u.IsActive ? "activated" : "deactivated")}!";
        await LoadData();
    }

    private void CloseModal() => showModal = false;
}