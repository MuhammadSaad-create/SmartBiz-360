@page "/productivity"
@layout EmptyLayout
@inject ProductivityService ProductivityService
@inject SessionService SessionService
@inject NavigationManager Navigation
@inject EmailService EmailService
@inject AppDbContext Db
@inject IJSRuntime JS

<div class="dashboard-layout">

    <AppSidebar CurrentPage="productivity" />

    <div class="main-content">
        <div class="topbar">
            <div>
                <h2 class="page-title">Productivity Score Engine</h2>
                <p class="page-sub">
                    Daily scores calculated from activity patterns.
                </p>
            </div>
            <div class="topbar-right">
                @if (SessionService.CurrentUser?.Role != "Employee")
                {
                    <button class="btn-primary"
                            @onclick="RecalculateAll"
                            disabled="@isCalculating">
                        @(isCalculating ? "Calculating..." :
                                            "⟳ Recalculate All")
                </button>
                                }
            </div>
        </div>

        @if (!string.IsNullOrEmpty(message))
        {
            <div class="alert-success">@message</div>
        }

        <!-- Disclaimer -->
        <div style="background:#fef9c3;border:1px solid #fde68a;
                    border-radius:8px;padding:0.75rem 1rem;
                    margin-bottom:1rem;font-size:0.85rem;
                    color:#92400e;">
            ⚠️ <strong>Disclaimer:</strong> This score reflects
            digital activity patterns, not work quality.
        </div>

        <!-- Team Average — hide for employees -->
        @if (SessionService.CurrentUser?.Role != "Employee")
        {
            <div class="stats-grid" style="margin-bottom:1rem;">
                <div class="stat-card">
                    <div class="stat-label">Team Average Today</div>
                    <div class="stat-value">
                        @teamAverage.ToString("F1")%
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Employees Scored</div>
                    <div class="stat-value">@scores.Count</div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">High Performers</div>
                    <div class="stat-value" style="color:#16a34a;">
                        @scores.Count(s => s.FinalScore >= 80)
                    </div>
                </div>
                <div class="stat-card">
                    <div class="stat-label">Needs Attention</div>
                    <div class="stat-value" style="color:#dc2626;">
                        @scores.Count(s => s.FinalScore < 50)
                    </div>
                </div>
            </div>
        }

        <!-- Scores Table -->
        <div class="data-card">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Employee</th>
                        <th>Active Time</th>
                        <th>App Usage</th>
                        <th>Keyboard</th>
                        <th>Task Rate</th>
                        <th>Score</th>
                        @if (SessionService.CurrentUser?.Role
                                                != "Employee")
                        {
                            <th>Adjust</th>
                        }
                    </tr>
                </thead>
                <tbody>
                    @foreach (var s in scores)
                    {
                        <tr>
                            <td>
                                <div class="emp-name">
                                    @s.Employee.User.FullName
                                </div>
                                <div class="emp-email">
                                    @s.Employee.Department
                                </div>
                            </td>
                            <td>
                                @((s.ActiveTimeRatio * 100)
                                                            .ToString("F0"))%
                                                                        </td>
                                                                        <td>
                                @((s.ProductiveAppUsage * 100)
                                                            .ToString("F0"))%
                                                                        </td>
                                                                        <td>
                                @((s.KeyboardIntensity * 100)
                                                            .ToString("F0"))%
                                                                        </td>
                                                                        <td>
                                @((s.TaskCompletionRate * 100)
                                                            .ToString("F0"))%
                        </td>
                        <td>
                            <div style="display:flex;
                                    align-items:center;gap:0.5rem;">
                                <div style="background:#f3f4f6;
                                        border-radius:9999px;
                                        height:8px;width:80px;">
                                    <div style="background:
                                            @GetScoreColor(
                                                                                             s.FinalScore);
                                            border-radius:9999px;
                                            height:8px;
                                            width:@((int)s.FinalScore)%;">
                                    </div>
                                </div>
                                <strong>
                                    @s.FinalScore.ToString("F0")
                                </strong>
                            </div>
                            @if (s.ManualAdjustment != 0)
                                {
                                    <div style="font-size:0.75rem;
                                                color:#6b7280;">
                                        Adj: @(s.ManualAdjustment > 0
                                                                        ? "+" : "")
                                @s.ManualAdjustment
                            </div>
                                                        }
                            </td>
                            @if (SessionService.CurrentUser?.Role
                                                    != "Employee")
                            {
                                <td>
                                    <button class="btn-icon"
                                            @onclick="() =>
                                            ShowAdjustModal(s)">
                                ✏️
                            </button>
                        </td>
                                                }
                        </tr>
                    }
                    @if (!scores.Any())
                    {
                        <tr>
                            <td colspan="7" class="empty-row">
                                No scores yet. Click
                                "Recalculate All" to generate
                                today's scores.
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>

@if (showAdjustModal && selectedScore != null)
{
    <div style="position:fixed;top:0;left:0;width:100vw;
                    height:100vh;background:rgba(0,0,0,0.5);
                    z-index:99999;display:flex;align-items:center;
                    justify-content:center;">
        <div style="background:white;border-radius:12px;
                        width:420px;padding:2rem;
                        box-shadow:0 8px 32px rgba(0,0,0,0.2);">
            <h3 style="margin:0 0 1rem;">Manual Adjustment</h3>
            <p style="color:#6b7280;font-size:0.85rem;">
                Adjust score for
                <strong>
                    @selectedScore.Employee.User.FullName
                </strong>.
                Range: -10 to +10. A note is required.
            </p>

            @if (!string.IsNullOrEmpty(adjustError))
            {
                <div class="alert-error">@adjustError</div>
            }

            <div class="form-group">
                <label>Adjustment (-10 to +10)</label>
                <input type="number" @bind="adjustValue"
                       min="-10" max="10"
                       style="width:100%;padding:0.6rem;
                                  border:1px solid #ddd;
                                  border-radius:6px;
                                  box-sizing:border-box;" />
            </div>
            <div class="form-group">
                <label>Reason (required)</label>
                <input @bind="adjustNote"
                       placeholder="Explain the adjustment..."
                       style="width:100%;padding:0.6rem;
                                  border:1px solid #ddd;
                                  border-radius:6px;
                                  box-sizing:border-box;" />
            </div>

            <div style="display:flex;justify-content:flex-end;
                            gap:0.75rem;margin-top:1.5rem;">
                <button class="btn-secondary"
                        @onclick="CloseAdjustModal">
                    Cancel
                </button>
                <button class="btn-primary"
                        @onclick="ApplyAdjustment">
                    Apply
                </button>
            </div>
        </div>
    </div>
}

@code {
    private List<ProductivityScore> scores = new();
    private double teamAverage = 0;
    private bool isCalculating = false;
    private string message = "";
    private bool showAdjustModal = false;
    private ProductivityScore? selectedScore;
    private int adjustValue = 0;
    private string adjustNote = "";
    private string adjustError = "";

    protected override async Task OnInitializedAsync()
    {
        if (SessionService.CurrentUser == null)
        {
            Navigation.NavigateTo("/login");
            return;
        }
        await LoadData();
    }

    private async Task LoadData()
    {
        var allScores = await ProductivityService.GetAllAsync();

        // Employees only see their own score
        if (SessionService.CurrentUser?.Role == "Employee")
        {
            scores = allScores.Where(s =>
                s.Employee.UserId ==
                SessionService.CurrentUser.Id)
                .ToList();
        }
        else
        {
            scores = allScores;
            teamAverage = await ProductivityService
                .GetTeamAverageAsync();
        }
    }

    private async Task RecalculateAll()
    {
        isCalculating = true;
        await ProductivityService.CalculateAllEmployeesAsync();
        await LoadData();

        // Send productivity digest to all managers
        var managers = await Db.Users
            .Where(u => u.Role == "Manager" ||
                        u.Role == "Admin")
            .ToListAsync();

        foreach (var manager in managers)
        {
            await EmailService.SendProductivityDigestAsync(
                manager.Email,
                manager.FullName,
                teamAverage,
                scores.Count);
        }

        message = $"Scores recalculated! " +
            $"Digest sent to {managers.Count} managers.";
        isCalculating = false;
    }

    private void ShowAdjustModal(ProductivityScore s)
    {
        selectedScore = s;
        adjustValue = 0;
        adjustNote = "";
        adjustError = "";
        showAdjustModal = true;
    }

    private async Task ApplyAdjustment()
    {
        adjustError = "";
        if (string.IsNullOrWhiteSpace(adjustNote))
        {
            adjustError = "A reason is required.";
            return;
        }
        if (adjustValue < -10 || adjustValue > 10)
        {
            adjustError = "Adjustment must be between -10 and +10.";
            return;
        }
        await ProductivityService.ApplyManualAdjustmentAsync(
            selectedScore!.Id, adjustValue, adjustNote);
        await LoadData();
        CloseAdjustModal();
        message = "Adjustment applied successfully!";
    }

    private void CloseAdjustModal() => showAdjustModal = false;

    private string GetScoreColor(double score) => score switch
    {
        >= 80 => "#16a34a",
        >= 60 => "#ca8a04",
        >= 40 => "#ea580c",
        _ => "#dc2626"
    };
}